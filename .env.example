# ─── REQUIRED ────────────────────────────────────────────────
VAULT_KEY=change_this_to_exactly_32_chars_min!
APP_SECRET=change_this_to_64_random_chars_for_jwt_security_do_not_share!!

# ─── DATABASE ────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/xops

# ─── REDIS (optional) ────────────────────────────────────────
# Leave empty to disable Redis — the app runs fine without it
REDIS_URL=

# ─── AI ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
AI_MODEL=claude-sonnet-4-20250514

# ─── BROWSER ─────────────────────────────────────────────────
PLAYWRIGHT_HEADLESS=true
BROWSER_LIMIT=5
SESSION_DIR=./data/sessions

# ─── SERVER ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
LOG_LEVEL=info
JWT_EXPIRES=24h

# ─── DAILY CAPS ──────────────────────────────────────────────
CAP_FOLLOW=50
CAP_LIKE=100
CAP_REPLY=30
CAP_POST=10
DELAY_MIN_MS=3000
DELAY_MAX_MS=12000
